# 1Password Vault Configuration
# Set these to your 1Password vault and environment names
# e.g., OP_VAULT=octospark-services OP_ENV=staging
OP_VAULT=<vault>
OP_ENV=<environment>

NODE_ENV=staging
LOG_LEVEL=warn
API_PORT=4000
API_HOST=0.0.0.0
DATABASE_URL=op://${OP_VAULT}/${OP_ENV}/DATABASE_URL
AUTH_SECRET=op://${OP_VAULT}/${OP_ENV}/AUTH_SECRET
API_CORS_ORIGIN=op://${OP_VAULT}/${OP_ENV}/API_CORS_ORIGIN
API_EXTERNAL_BASE_URL=op://${OP_VAULT}/${OP_ENV}/API_EXTERNAL_BASE_URL
WEB_BASE_URL=op://${OP_VAULT}/${OP_ENV}/WEB_BASE_URL
RESEND_API_KEY=op://${OP_VAULT}/${OP_ENV}/RESEND_API_KEY
RESEND_FROM_EMAIL=op://${OP_VAULT}/${OP_ENV}/RESEND_FROM_EMAIL
TEMPORAL_RUNTIME_MODE=cloud
TEMPORAL_ADDRESS=op://${OP_VAULT}/${OP_ENV}/TEMPORAL_ADDRESS
TEMPORAL_NAMESPACE=op://${OP_VAULT}/${OP_ENV}/TEMPORAL_NAMESPACE
TEMPORAL_TASK_QUEUE=op://${OP_VAULT}/${OP_ENV}/TEMPORAL_TASK_QUEUE
TEMPORAL_API_KEY=op://${OP_VAULT}/${OP_ENV}/TEMPORAL_API_KEY
TEMPORAL_TLS_ENABLED=true
TEMPORAL_TLS_SERVER_NAME=
# Optional Temporal TLS PEM material (for namespace-specific cert auth)
# TEMPORAL_TLS_CA_CERT_PEM=<set via runtime env or vault field TEMPORAL_TLS_CA_CERT_PEM>
# TEMPORAL_TLS_CLIENT_CERT_PEM=<set via runtime env or vault field TEMPORAL_TLS_CLIENT_CERT_PEM>
# TEMPORAL_TLS_CLIENT_KEY_PEM=<set via runtime env or vault field TEMPORAL_TLS_CLIENT_KEY_PEM>
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_LOGS_EXPORTER=otlp
# Optional Sentry error reporting for worker (errors only; tracing disabled)
# WORKER_SENTRY_DSN=<set via runtime env or vault field WORKER_SENTRY_DSN>
OTEL_COLLECTOR_BACKEND=gcp
OTEL_SERVICE_NAMESPACE=<service_namespace>
GOOGLE_CLOUD_PROJECT=op://${OP_VAULT}/${OP_ENV}/GOOGLE_CLOUD_PROJECT
GOOGLE_APPLICATION_CREDENTIALS=
OTEL_COLLECTOR_GCP_CREDENTIALS_DIR=./deploy/gcp-empty
OTEL_COLLECTOR_GCLOUD_CONFIG_DIR=./deploy/gcloud-empty
OTEL_JAEGER_ENDPOINT=http://jaeger:4318
OTEL_PROMETHEUS_OTLP_ENDPOINT=http://prometheus:9090/api/v1/otlp
OTEL_LOKI_OTLP_ENDPOINT=http://loki:3100/otlp
# Optional Cloudflare tunnel settings for Mac k3s API exposure
# CLOUDFLARE_TUNNEL_ID=<set via workflow secret CLOUDFLARE_TUNNEL_ID>
# CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=<set via workflow secret CLOUDFLARE_TUNNEL_CREDENTIALS_FILE>
# CLOUDFLARE_TUNNEL_HOST_DEV=<set via workflow secret CLOUDFLARE_TUNNEL_HOST_DEV>
# CLOUDFLARE_TUNNEL_HOST_STAGING=<set via workflow secret CLOUDFLARE_TUNNEL_HOST_STAGING>
# CLOUDFLARE_TUNNEL_HOST_PROD=<set via workflow secret CLOUDFLARE_TUNNEL_HOST_PROD>
# CLOUDFLARE_TUNNEL_UPSTREAM_DEV=http://127.0.0.1:4000
